// GraphViz DOT for cttnalt2 view

graph cttnalt2 {
  rankdir=TB;
  splines=true;
  overlap=false;
  nodesep=1.0;
  ranksep=0.8;
  node [shape=circle, style=filled, width=0.6, fixedsize=true, fontsize=12, fontname="Helvetica", fontcolor="#ffffff"];
  edge [color="#666666", penwidth=1.0];

  // nodes (1..24 blue, 25..48 red)
    // nodes recolored per request:
    // 1-8: purple, 9-16: yellow, 17-32: red, 33-48: blue

    // purple 1..8
    node [fillcolor="#6f42c1", fontcolor="#ffffff"]
    1 [label="1"];
    2 [label="2"];
    3 [label="3"];
    4 [label="4"];
    5 [label="5"];
    6 [label="6"];
    7 [label="7"];
    8 [label="8"];

    // yellow 9..16 (use dark font for contrast)
    node [fillcolor="#f1c40f", fontcolor="#333333"]
    9  [label="9"];
    10 [label="10"];
    11 [label="11"];
    12 [label="12"];
    13 [label="13"];
    14 [label="14"];
    15 [label="15"];
    16 [label="16"];

    // red 17..32
    node [fillcolor="#d9534f", fontcolor="#ffffff"]
    17 [label="17"];
    18 [label="18"];
    19 [label="19"];
    20 [label="20"];
    21 [label="21"];
    22 [label="22"];
    23 [label="23"];
    24 [label="24"];
    25 [label="25", tooltip="25"];
    26 [label="26", tooltip="26"];
    27 [label="27", tooltip="27"];
    28 [label="28", tooltip="28"];
    29 [label="29", tooltip="29"];
    30 [label="30", tooltip="30"];
    31 [label="31", tooltip="31"];
    32 [label="32", tooltip="32"];

    // blue 33..48
    node [fillcolor="#3b78d8", fontcolor="#ffffff"]
    33 [label="33", tooltip="33"];
    34 [label="34", tooltip="34"];
    35 [label="35", tooltip="35"];
    36 [label="36", tooltip="36"];
    37 [label="37", tooltip="37"];
    38 [label="38", tooltip="38"];
    39 [label="39", tooltip="39"];
    40 [label="40", tooltip="40"];
    41 [label="41", tooltip="41"];
    42 [label="42", tooltip="42"];
    43 [label="43", tooltip="43"];
    44 [label="44", tooltip="44"];
    45 [label="45", tooltip="45"];
    46 [label="46", tooltip="46"];
    47 [label="47", tooltip="47"];
    48 [label="48", tooltip="48"];

    // Arrange as a 3-tine fork: top row (1..8), middle row (17..48), bottom row (9..16)
    {
      rank = same;
      1; 2; 3; 4; 5; 6; 7; 8;
    }

    
    // edges (label = bond dim, penwidth = min(0.6 + 0.6*dim, 10))
    21 -- 37 [label="25", penwidth=10, fontsize=20, fontcolor="#333333"];
    22 -- 37 [label="15", penwidth=9.6, fontsize=20, fontcolor="#333333"];
    22 -- 38 [label="25", penwidth=10, fontsize=20, fontcolor="#333333"];
    23 -- 38 [label="15", penwidth=9.6, fontsize=20, fontcolor="#333333"];
    23 -- 39 [label="20", penwidth=10, fontsize=20, fontcolor="#333333"];
    24 -- 39 [label="12", penwidth=7.8, fontsize=20, fontcolor="#333333"];
    24 -- 40 [label="20", penwidth=10, fontsize=20, fontcolor="#333333"];
    25 -- 40 [label="12", penwidth=7.8, fontsize=20, fontcolor="#333333"];
    25 -- 41 [label="13", penwidth=8.4, fontsize=20, fontcolor="#333333"];
    26 -- 41 [label="8", penwidth=5.4, fontsize=20, fontcolor="#333333"];
    26 -- 42 [label="13", penwidth=8.4, fontsize=20, fontcolor="#333333"];
    27 -- 42 [label="9", penwidth=6.0, fontsize=20, fontcolor="#333333"];
    27 -- 43 [label="15", penwidth=9.6, fontsize=20, fontcolor="#333333"];
    28 -- 43 [label="9", penwidth=6.0, fontsize=20, fontcolor="#333333"];
    28 -- 44 [label="15", penwidth=9.6, fontsize=20, fontcolor="#333333"];
    29 -- 44 [label="9", penwidth=6.0, fontsize=20, fontcolor="#333333"];
    29 -- 45 [label="15", penwidth=9.6, fontsize=20, fontcolor="#333333"];
    30 -- 45 [label="9", penwidth=6.0, fontsize=20, fontcolor="#333333"];
    30 -- 46 [label="7", penwidth=4.8, fontsize=20, fontcolor="#333333"];
    31 -- 46 [label="4", penwidth=3.0, fontsize=20, fontcolor="#333333"];
    31 -- 47 [label="5", penwidth=3.6, fontsize=20, fontcolor="#333333"];
    32 -- 47 [label="3", penwidth=2.4, fontsize=20, fontcolor="#333333"];
    32 -- 48 [label="2", penwidth=1.8, fontsize=20, fontcolor="#333333"];

    21 -- 36 [label="18", penwidth=10, fontsize=20, fontcolor="#333333"];
    20 -- 36 [label="30", penwidth=10, fontsize=20, fontcolor="#333333"];
    20 -- 35 [label="20", penwidth=10, fontsize=20, fontcolor="#333333"];
    19 -- 35 [label="33", penwidth=10, fontsize=20, fontcolor="#333333"];
    19 -- 34 [label="22", penwidth=10, fontsize=20, fontcolor="#333333"];
    18 -- 34 [label="34", penwidth=10, fontsize=20, fontcolor="#333333"];
    18 -- 33 [label="22", penwidth=10, fontsize=20, fontcolor="#333333"];
    17 -- 33 [label="20", penwidth=10, fontsize=20, fontcolor="#333333"];

    1 -- 17  [label="11", penwidth=7.2, fontsize=20, fontcolor="#333333"];
    1 -- 2   [label="11", penwidth=7.2, fontsize=20, fontcolor="#333333"];
    2 -- 3   [label="11", penwidth=7.2, fontsize=20, fontcolor="#333333"];
    3 -- 4   [label="10", penwidth=6.6, fontsize=20, fontcolor="#333333"];
    4 -- 5   [label="8", penwidth=5.4, fontsize=20, fontcolor="#333333"];
    5 -- 6   [label="6", penwidth=4.2, fontsize=20, fontcolor="#333333"];
    6 -- 7   [label="4", penwidth=3.0, fontsize=20, fontcolor="#333333"];
    7 -- 8   [label="2", penwidth=1.8, fontsize=20, fontcolor="#333333"];

    9 -- 17  [label="11", penwidth=7.2, fontsize=20, fontcolor="#333333"];
    9 -- 10  [label="11", penwidth=7.2, fontsize=20, fontcolor="#333333"];
    10 -- 11 [label="11", penwidth=7.2, fontsize=20, fontcolor="#333333"];
    11 -- 12 [label="10", penwidth=6.6, fontsize=20, fontcolor="#333333"];
    12 -- 13 [label="8", penwidth=5.4, fontsize=20, fontcolor="#333333"];
    13 -- 14 [label="6", penwidth=4.2, fontsize=20, fontcolor="#333333"];
    14 -- 15 [label="4", penwidth=3.0, fontsize=20, fontcolor="#333333"];
    15 -- 16 [label="2", penwidth=1.8, fontsize=20, fontcolor="#333333"];

    // invisible alignment edges to left-align the three tines (left edge at nodes 1,17,9)
    1 -- 17 [style=invis, weight=100];
    1 -- 9  [style=invis, weight=100];

}

